*.xgb

# Synth detector weight cache
#   Default: ~/.cache/synth/weights/
#   Guard against local overrides via SYNTH_CACHE_DIR
.synth_cache/
synth_weights/

# EasyOCR model cache (default download location)
~/.EasyOCR/
.EasyOCR/

# HuggingFace model cache
#   Default: ~/.cache/huggingface/  (outside project)
#   Guard against local overrides via HF_HOME or TRANSFORMERS_CACHE
*.cache/
huggingface/
hub/
models--*/

